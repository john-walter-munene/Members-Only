<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <link rel="icon" href="https://www.flaticon.com/free-icons/smart-key" />
    <link rel="stylesheet" href="/css/new-post.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/footer.css">
    <title>Members Only</title>
</head>

<body>

    <header>
        <%- include("partials/header") %>
    </header>

    <main>

        <section class="membership-house">

            <form action="/new-post" method="post" class="membership-form">
                <div class="title">
                    <label for="title"><p>Title</p></label>
                    <input type="text" id="title" name="title" 
                        placeholder="Enter the title of your message" autocomplete="off" required />
                </div>

                <div class="post">
                    <label for="post"><p>Message</p></label>
                    <textarea id="post" name="post" rows="6" 
                        placeholder="Enter your message here" autocomplete="off" required></textarea>
                </div>

                <button type="submit">Submit</button>
            </form>
        </section>

    </main>

    <footer>
        <%- include("partials/footer") %>
    </footer>

</body>
</html>